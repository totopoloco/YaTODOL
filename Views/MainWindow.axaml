<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:YATODOL"
        mc:Ignorable="d" d:DesignWidth="880" d:DesignHeight="780"
        x:Class="YATODOL.Views.MainWindow"
        Icon="avares://YATODOL/app-icon.png"
        Title="YATODOL" Width="880" Height="780">

    <Grid ColumnDefinitions="192,*">

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- App title -->
                <Border DockPanel.Dock="Top" Padding="14,18,14,16"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock x:Name="HeaderLabel" FontSize="20" FontWeight="Bold"/>
                </Border>

                <!-- Sidebar navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,14,8,14" Spacing="2">

                        <!-- Navigation group -->
                        <TextBlock x:Name="SidebarNavLabel"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="6,0,0,6"/>
                        <Button x:Name="TodayButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnTodayClick"/>
                        <Button x:Name="DeleteDateButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnDeleteDateClick"/>

                        <Border Height="1"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                Margin="4,10,4,10"/>

                        <!-- Tasks group -->
                        <TextBlock x:Name="SidebarTasksLabel"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="6,0,0,6"/>
                        <Button x:Name="PrintButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnPrintClick"/>
                        <Button x:Name="ImportButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnImportClick"/>
                        <Button x:Name="ExportButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnExportClick"/>
                        <Button x:Name="ICalButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnICalExportClick"/>

                        <Border Height="1"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                Margin="4,10,4,10"/>

                        <!-- App group -->
                        <TextBlock x:Name="SidebarAppLabel"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="6,0,0,6"/>
                        <Button x:Name="SettingsButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnSettingsClick"/>
                        <Button x:Name="AboutButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Click="OnAboutClick"/>

                        <Border Height="1"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                Margin="4,10,4,10"/>

                        <!-- Filter group -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                            <TextBlock x:Name="SidebarFilterLabel"
                                       Grid.Column="0"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="FilterClearButton"
                                    Grid.Column="1"
                                    FontSize="10" Padding="4,2"
                                    IsVisible="False"
                                    Click="OnFilterClearClick"/>
                        </Grid>
                        <WrapPanel x:Name="FilterTagsPanel" Margin="2,0,2,0"/>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <DockPanel Grid.Column="1" Margin="20,16,16,16">

            <!-- Date navigation -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6"
                        Margin="0,0,0,12" VerticalAlignment="Center">
                <Button x:Name="PrevDayButton" Content="◀" Click="OnPrevDay"
                        Padding="8,6" FontSize="12" VerticalAlignment="Center"/>
                <CalendarDatePicker x:Name="DatePicker"
                                    IsTodayHighlighted="True"
                                    VerticalAlignment="Center"/>
                <Button x:Name="NextDayButton" Content="▶" Click="OnNextDay"
                        Padding="8,6" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Input area -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBox x:Name="NewItemBox" Grid.Column="0" Margin="0,0,8,0"
                         PlaceholderText="Add a new task..."
                         KeyDown="OnInputKeyDown"/>
                <Button x:Name="AddButton" Grid.Column="1" Classes="accent"
                        VerticalAlignment="Stretch" Click="OnAddClick"/>
            </Grid>

            <!-- Warning label -->
            <TextBlock x:Name="WarningLabel" DockPanel.Dock="Top" Foreground="#c0675e"
                       FontSize="12" Margin="0,0,0,6" IsVisible="False"/>

            <!-- Count label -->
            <TextBlock x:Name="CountLabel" DockPanel.Dock="Top" Foreground="Gray"
                       FontSize="12" Margin="0,0,0,8"/>

            <!-- Search bar -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Margin="0,0,6,0"
                         PlaceholderText="Search..."
                         TextChanged="OnSearchTextChanged"/>
                <ToggleButton x:Name="RegexToggleButton" Grid.Column="1"
                              Content=".*"
                              FontFamily="Consolas,Courier New,monospace"
                              FontSize="12" Padding="8,6"
                              IsCheckedChanged="OnRegexToggleChanged"/>
            </Grid>

            <!-- Accordion task list -->
            <ScrollViewer>
                <StackPanel x:Name="AccordionPanel" Spacing="4"/>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</Window>
