<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="420"
        x:Class="YATODOL.AboutWindow"
        Title="About YaTODOL" Width="480" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="avares://YATODOL/app-icon.png">

    <DockPanel Margin="24">
        <!-- Header with icon and title -->
        <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Image Source="avares://YATODOL/app-icon.png" Width="64" Height="64"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="YaTODOL" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionLabel" Text="Version"
                       Foreground="Gray" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <TextBlock Text="Yet another todo list"
                       Foreground="Gray" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Close button -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Click="OnCloseClick" Width="90" Padding="12,8"/>
        </StackPanel>

        <!-- Release notes -->
        <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="4">
            <ScrollViewer>
                <TextBlock x:Name="ReleaseNotesText"
                           TextWrapping="Wrap" FontSize="13"
                           Margin="12,8" LineHeight="20"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
