<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="680"
        x:Class="YATODOL.SettingsWindow"
        Title="Settings" Width="500" Height="740"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="avares://YATODOL/app-icon.png">

    <DockPanel Margin="24">
        <!-- Title -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock x:Name="SettingsTitleText" Text="⚙ Settings" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="SettingsSubtitleText" Text="Customize how YATODOL behaves"
                       Foreground="Gray" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Buttons (dock first so they always appear) -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" Width="90" Padding="12,8"/>
            <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick" Classes="accent" Width="90" Padding="12,8"/>
        </StackPanel>

        <!-- Settings list (fills remaining space) -->
        <ScrollViewer>
            <StackPanel Spacing="20" Margin="0,0,16,0">

                <!-- Appearance section -->
                <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="AppearanceSectionText" Text="Appearance" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <RadioButton x:Name="ThemeLight" Content="☀ Light" GroupName="Theme"/>
                            <RadioButton x:Name="ThemeDark" Content="🌙 Dark" GroupName="Theme"/>
                            <RadioButton x:Name="ThemeSystem" Content="💻 System" GroupName="Theme"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- General section -->
                <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="GeneralSectionText" Text="General" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,6"/>
                        <CheckBox x:Name="ShowPathCheck">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="ShowPathLabelText" Text="Show file path in title bar"/>
                                <TextBlock x:Name="ShowPathDescText"
                                           Text="Displays the data file location in the window title"
                                           Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="HideCompletedDatesCheck">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="HideCompletedLabelText" Text="Hide fully completed dates"/>
                                <TextBlock x:Name="HideCompletedDescText"
                                           Text="Dates where all tasks are done will be hidden from the list"
                                           Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="CarryForwardCheck">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="CarryForwardLabelText" Text="Carry forward uncompleted tasks"/>
                                <TextBlock x:Name="CarryForwardDescText"
                                           Text="Moves past uncompleted tasks to today automatically at midnight"
                                           Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- Data Storage section -->
                <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="StorageSectionText" Text="Data Storage" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,6"/>
                        <CheckBox x:Name="CustomPathCheck" Click="OnCustomPathCheckChanged">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="CustomPathLabelText" Text="Use custom data folder"/>
                                <TextBlock x:Name="CustomPathDescText"
                                           Text="Store todos.json in a custom location (e.g. a shared network folder)"
                                           Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </CheckBox>
                        <Grid x:Name="CustomPathPanel" ColumnDefinitions="*,Auto" Margin="28,4,0,0"
                              IsVisible="False">
                            <TextBox x:Name="CustomPathBox" IsReadOnly="True"
                                     PlaceholderText="Select a folder..." Grid.Column="0"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="BrowseButton" Content="📁 Browse" Grid.Column="1"
                                    Click="OnBrowseClick" Padding="8,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Print section -->
                <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="PrintSectionText" Text="🖨 Printing" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,2"/>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="PrintScopeLabelText" Text="Scope" FontSize="12" Foreground="Gray"
                                       Margin="0,0,0,2"/>
                            <RadioButton x:Name="ScopeSelectedDate" Content="Selected date only"
                                         GroupName="PrintScope" IsChecked="True"/>
                            <RadioButton x:Name="ScopeAllDates" Content="All dates"
                                         GroupName="PrintScope"/>
                        </StackPanel>

                        <Border Height="1" Background="#18888888" Margin="0,2"/>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="PrintFilterLabelText" Text="Filter" FontSize="12" Foreground="Gray"
                                       Margin="0,0,0,2"/>
                            <RadioButton x:Name="FilterAll" Content="All items (active + completed)"
                                         GroupName="PrintFilter" IsChecked="True"/>
                            <RadioButton x:Name="FilterRemaining" Content="Remaining only (hide completed)"
                                         GroupName="PrintFilter"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Language section -->
                <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="LanguageSectionText" Text="Language" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="LanguagePickerLabelText" Text="Interface language"
                                   FontSize="12" Foreground="Gray"/>
                        <ComboBox x:Name="LanguageCombo" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
