<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="440"
        x:Class="YATODOL.NoteEditorWindow"
        Title="Task Note" Width="520" Height="440"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Icon="avares://YATODOL/app-icon.png">

    <DockPanel Margin="20">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Text="Task Note" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="SubtitleText" Text="Note for: task"
                       Foreground="Gray" FontSize="12" Margin="0,4,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="DeleteNoteButton" Content="Delete Note" Click="OnDeleteNoteClick"
                    Foreground="#e74c3c" Padding="12,8"/>
            <Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" Width="90" Padding="12,8"/>
            <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick" Classes="accent" Width="90" Padding="12,8"/>
        </StackPanel>

        <!-- Editor -->
        <Border BorderBrush="#30888888" BorderThickness="1" CornerRadius="6">
            <TextBox x:Name="NoteEditor" AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap" FontSize="14" FontFamily="Consolas, monospace"
                     Padding="10" BorderThickness="0"
                     PlaceholderText=""/>
        </Border>
    </DockPanel>
</Window>
