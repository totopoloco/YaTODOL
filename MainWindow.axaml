<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:YATODOL"
        mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
        x:Class="YATODOL.MainWindow"
        Icon="avares://YATODOL/app-icon.png"
        Title="YATODOL" Width="850" Height="600">

    <DockPanel Margin="16">
        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock Text="Yet Another To Do List"
                       FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button x:Name="PrevDayButton" Content="◀" Click="OnPrevDay"
                        Padding="6,4" FontSize="12"/>
                <CalendarDatePicker x:Name="DatePicker"
                                    IsTodayHighlighted="True"/>
                <Button x:Name="NextDayButton" Content="▶" Click="OnNextDay"
                        Padding="6,4" FontSize="12"/>
                <Button Content="Today" Click="OnTodayClick" Padding="8,4"/>
                <Button Content="🗑" Click="OnDeleteDateClick" Padding="6,4"
                        FontSize="12" ToolTip.Tip="Delete all tasks for selected date"/>
            </StackPanel>
        </Grid>

        <!-- Input area -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBox x:Name="NewItemBox" PlaceholderText="Add a new task..."
                     Grid.Column="0" Margin="0,0,8,0"
                     KeyDown="OnInputKeyDown"/>
            <Button x:Name="AddButton" Content="Add" Grid.Column="1"
                    Click="OnAddClick" Classes="accent"
                    VerticalAlignment="Stretch"/>
        </Grid>

        <!-- Status -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock x:Name="CountLabel" Foreground="Gray"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="🖨 Print" Click="OnPrintClick" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                <Button Content="📥 Import" Click="OnImportClick" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                <Button Content="📤 Export" Click="OnExportClick" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                <Button Content="📅 iCal" Click="OnICalExportClick" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                        ToolTip.Tip="Export tasks to iCalendar (.ics)"/>
                <Button Content="⚙ Settings" Click="OnSettingsClick" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                <Button Content="ℹ" Click="OnAboutClick" Padding="6,4"
                        FontSize="12" ToolTip.Tip="About YaTODOL"/>
            </StackPanel>
        </Grid>

        <!-- Accordion task list -->
        <ScrollViewer>
            <StackPanel x:Name="AccordionPanel" Spacing="4"/>
        </ScrollViewer>
    </DockPanel>
</Window>
