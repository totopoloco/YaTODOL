#!/bin/sh
set -e

# Update icon cache
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
  gtk-update-icon-cache -f -t /usr/share/icons/hicolor || true
fi

# Update desktop database
if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database /usr/share/applications || true
fi

# Ensure .desktop file is executable (required by some GNOME versions)
chmod 755 /usr/share/applications/yatodol.desktop 2>/dev/null || true

# Install to each logged-in user's local applications dir for reliable GNOME detection
for USER_HOME in /home/*; do
  USER_NAME=$(basename "$USER_HOME")
  if id "$USER_NAME" >/dev/null 2>&1; then
    LOCAL_APP_DIR="${USER_HOME}/.local/share/applications"
    mkdir -p "$LOCAL_APP_DIR"
    cp /usr/share/applications/yatodol.desktop "$LOCAL_APP_DIR/"
    chmod 755 "$LOCAL_APP_DIR/yatodol.desktop"
    chown "$USER_NAME":"$USER_NAME" "$LOCAL_APP_DIR/yatodol.desktop"
  fi
done
